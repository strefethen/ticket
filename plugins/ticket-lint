#!/usr/bin/env bash
# tk-plugin: Validate tickets against the handoff schema
# tk-plugin-version: 0.5.1
#
# Usage:
#   tk lint <id>           Check one ticket, pretty output, exit 0 pass / 1 fail
#   tk lint --all          Check every ticket in TICKETS_DIR
#   tk lint <id> --json    Emit JSON result
#   tk lint --all --json   Emit JSON array
#
# Required for plan-ready handoff:
#   frontmatter: writes (non-empty), plan (set — EXEMPT for type:bug),
#                an `epic:*` tag
#   body:        ## Goal (non-empty), ## Design (non-empty),
#                ## Acceptance Criteria (non-empty),
#                ## Testing Obligations (non-empty)
#   reads:       present but may be empty (warn)
#   type/priority are NOT gated in v1 — default values can't be distinguished
#   from explicit ones without parsing create-time arg history.
#
# `plan:` exemption for bugs: bugs are often reactive (discovered during
# other work, filed as follow-ups) and don't have a source plan document.
# Requiring `plan:` on them would either force a fake plan reference or
# block legitimate tickets at handoff. Bugs still need Goal / Design /
# Acceptance / Testing Obligations — the exemption is scoped to plan
# linkage only.
#
# Epic membership is mandatory. Every ticket must carry at least one
# `epic:<kebab-name>` tag. Discover existing epics via `tk epics`; define
# new ones only after user confirmation (see the ticket-writer skill).
#
# `## Inputs / Outputs` is conditional (required when the ticket produces
# or consumes a typed interface) and deliberately NOT lint-gated —
# discipline lives in the ticket-writer skill, not in this plugin.

set -u

JSON=0
ALL=0
TICKET_ID=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --json) JSON=1; shift ;;
        --all)  ALL=1;  shift ;;
        -h|--help)
            cat <<'EOF'
tk lint — validate tickets against the handoff schema.

Usage:
  tk lint <id>            Check one ticket
  tk lint --all           Check every ticket in $TICKETS_DIR
  tk lint <id> --json     Emit JSON {ticket_id, overall, checks: [...]}
  tk lint --all --json    Emit JSON array of same shape

Exit codes:
  0   all lints pass
  1   one or more lints fail
EOF
            exit 0
            ;;
        -*) echo "Unknown flag: $1" >&2; exit 1 ;;
        *)  TICKET_ID="$1"; shift ;;
    esac
done

TICKETS_DIR="${TICKETS_DIR:-.tickets}"
if [[ ! -d "$TICKETS_DIR" ]]; then
    echo "Error: $TICKETS_DIR does not exist" >&2
    exit 1
fi

# Extract lint signals from a single file via awk.
# Output format (pipe-separated, one line):
#   writes_count|reads_count|plan|design_lines|acceptance_lines|type|priority|id
extract_signals() {
    awk '
    BEGIN {
        in_fm = 0; in_writes = 0; in_reads = 0; in_tags = 0;
        writes_count = 0; reads_count = 0; has_epic_tag = 0;
        plan = ""; type_ = ""; priority_ = ""; id_ = ""; status_ = "";
        goal_section = 0; goal_lines = 0;
        design_section = 0; design_lines = 0;
        acceptance_section = 0; acceptance_lines = 0;
        testing_section = 0; testing_lines = 0;
        close_reason = "";
    }
    /^---$/ {
        if (NR == 1) { in_fm = 1; next }
        else if (in_fm) { in_fm = 0; next }
    }
    in_fm {
        if ($1 == "id:") { id_ = $2 }
        else if ($1 == "status:") { status_ = $2 }
        else if ($1 == "plan:") { plan = $2 }
        else if ($1 == "type:") { type_ = $2 }
        else if ($1 == "priority:") { priority_ = $2 }
        else if (/^writes:/) { in_writes = 1; in_reads = 0; in_tags = 0; next }
        else if (/^reads:/)  { in_reads = 1;  in_writes = 0; in_tags = 0; next }
        else if (/^tags:/) {
            # Inline form: tags: [foo, epic:bar]. Also set multiline state
            # so subsequent "  - epic:x" lines are also scanned.
            line = $0
            sub(/^tags:[ ]*/, "", line)
            if (line ~ /epic:/) has_epic_tag = 1
            in_tags = 1; in_writes = 0; in_reads = 0
            next
        }
        if (/^  - /) {
            if (in_writes) writes_count++
            else if (in_reads) reads_count++
            else if (in_tags && /epic:/) has_epic_tag = 1
            next
        }
        if (/^[a-z]/) { in_writes = 0; in_reads = 0; in_tags = 0 }
    }
    !in_fm {
        if (/^## Goal$/)                { goal_section = 1; design_section = 0; acceptance_section = 0; testing_section = 0; next }
        if (/^## Design$/)              { design_section = 1; goal_section = 0; acceptance_section = 0; testing_section = 0; next }
        if (/^## Acceptance Criteria$/) { acceptance_section = 1; goal_section = 0; design_section = 0; testing_section = 0; next }
        if (/^## Testing Obligations$/) { testing_section = 1; goal_section = 0; design_section = 0; acceptance_section = 0; next }
        if (/^## /)                     { goal_section = 0; design_section = 0; acceptance_section = 0; testing_section = 0 }
        if (goal_section && $0 ~ /[^[:space:]]/)       goal_lines++
        if (design_section && $0 ~ /[^[:space:]]/)     design_lines++
        if (acceptance_section && $0 ~ /[^[:space:]]/) acceptance_lines++
        if (testing_section && $0 ~ /[^[:space:]]/)    testing_lines++
        # Capture the LAST "Closed: <reason>" line from the body — last
        # match wins so reopen+reclose cycles report the current reason.
        # The closure check in lint_one evaluates this only when
        # status is closed.
        if (/^Closed: /) close_reason = substr($0, 9)
    }
    END {
        # close_reason is last in the pipe order so bash read -r slurps
        # any "|" characters it may contain as part of the reason text.
        print writes_count "|" reads_count "|" plan "|" goal_lines "|" design_lines "|" acceptance_lines "|" testing_lines "|" type_ "|" priority_ "|" id_ "|" has_epic_tag "|" status_ "|" close_reason
    }
    ' "$1"
}

# Lint one file. Emits result to stdout in requested format; returns 0 or 1.
lint_one() {
    local file="$1"
    local signals
    signals=$(extract_signals "$file")
    IFS='|' read -r writes_count reads_count plan goal_lines design_lines acceptance_lines testing_lines type_ priority_ id_ has_epic_tag status_ close_reason <<< "$signals"
    [[ -z "$id_" ]] && id_=$(basename "$file" .md)

    # Evaluate checks. Each is (name|status|detail).
    local -a checks=()
    local overall="pass"

    if (( writes_count > 0 )); then
        checks+=("writes|pass|$writes_count path(s)")
    else
        checks+=("writes|fail|empty or missing")
        overall="fail"
    fi

    if (( reads_count > 0 )); then
        checks+=("reads|pass|$reads_count path(s)")
    else
        checks+=("reads|warn|absent or empty")
    fi

    if [[ -n "$plan" ]]; then
        checks+=("plan|pass|$plan")
    elif [[ "$type_" == "bug" ]]; then
        checks+=("plan|pass|not set (exempt for type:bug)")
    else
        checks+=("plan|fail|not set")
        overall="fail"
    fi

    # Epic membership is mandatory. Every ticket must carry at least one
    # `epic:*` tag. Discover existing epics via `tk epics`.
    if [[ "$has_epic_tag" == "1" ]]; then
        checks+=("epic|pass|epic:* tag present")
    else
        checks+=("epic|fail|no epic:* tag — run 'tk epics' and pick one")
        overall="fail"
    fi

    # Closure check (tlf-aapz): for tickets with status: closed, the
    # latest "Closed: <reason>" note must reference a commit hash
    # (7-40 hex chars anywhere in the text) OR the phrase "no commit"
    # for closed-without-code tickets. Warn-only; does not flip
    # overall. Silent for non-closed tickets.
    if [[ "$status_" == "closed" ]]; then
        if printf '%s' "$close_reason" | grep -Eq '[a-fA-F0-9]{7,40}'; then
            hash=$(printf '%s' "$close_reason" | grep -oE '[a-fA-F0-9]{7,40}' | head -1)
            checks+=("closure|pass|hash: $hash")
        elif printf '%s' "$close_reason" | grep -qi 'no commit'; then
            checks+=("closure|pass|\"no commit\" alternative")
        else
            checks+=("closure|warn|reason missing commit-hash reference")
        fi
    fi

    if (( goal_lines > 0 )); then
        checks+=("goal|pass|$goal_lines line(s)")
    else
        checks+=("goal|fail|## Goal section missing or empty")
        overall="fail"
    fi

    if (( design_lines > 0 )); then
        checks+=("design|pass|$design_lines line(s)")
    else
        checks+=("design|fail|## Design section missing or empty")
        overall="fail"
    fi

    if (( acceptance_lines > 0 )); then
        checks+=("acceptance|pass|$acceptance_lines line(s)")
    else
        checks+=("acceptance|fail|## Acceptance Criteria missing or empty")
        overall="fail"
    fi

    if (( testing_lines > 0 )); then
        checks+=("testing|pass|$testing_lines line(s)")
    else
        checks+=("testing|fail|## Testing Obligations section missing or empty")
        overall="fail"
    fi

    if (( JSON == 1 )); then
        # Build JSON via jq from the check triples.
        {
            printf '%s\n' "${checks[@]}"
        } | jq -Rn --arg id "$id_" --arg overall "$overall" '
            [inputs | split("|") | {rule: .[0], status: .[1], detail: .[2]}]
            | {ticket_id: $id, overall: $overall, checks: .}
        '
    else
        # Pretty output.
        local overall_label
        overall_label=$(printf '%s' "$overall" | tr '[:lower:]' '[:upper:]')
        echo "$id_  $overall_label"
        for c in "${checks[@]}"; do
            IFS='|' read -r rule status detail <<< "$c"
            local marker
            case "$status" in
                pass) marker="[x]" ;;
                warn) marker="[~]" ;;
                *)    marker="[ ]" ;;
            esac
            printf '  %s %-11s %s\n' "$marker" "$rule" "$detail"
        done
    fi

    [[ "$overall" == "pass" ]] && return 0 || return 1
}

# Main dispatch
if (( ALL == 1 )); then
    fail_count=0
    pass_count=0
    first=1
    if (( JSON == 1 )); then echo "["; fi
    for f in "$TICKETS_DIR"/*.md; do
        bn=$(basename "$f")
        case "$bn" in _*|index.md|_sidebar.json|closed-tickets.md) continue ;; esac

        if (( JSON == 1 )); then
            [[ $first -eq 0 ]] && echo ","
            first=0
            if lint_one "$f"; then
                pass_count=$((pass_count + 1))
            else
                fail_count=$((fail_count + 1))
            fi
        else
            if lint_one "$f"; then
                pass_count=$((pass_count + 1))
            else
                fail_count=$((fail_count + 1))
            fi
            echo
        fi
    done
    if (( JSON == 1 )); then echo "]"; fi
    if (( JSON == 0 )); then
        echo "summary: $pass_count pass, $fail_count fail"
    fi
    (( fail_count == 0 )) && exit 0 || exit 1
else
    if [[ -z "$TICKET_ID" ]]; then
        echo "Usage: tk lint <id>  |  tk lint --all" >&2
        exit 1
    fi
    # Resolve ticket file path
    file="$TICKETS_DIR/${TICKET_ID}.md"
    if [[ ! -f "$file" ]]; then
        echo "Error: ticket $TICKET_ID not found at $file" >&2
        exit 1
    fi
    lint_one "$file"
fi
