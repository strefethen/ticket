#!/usr/bin/env bash
# tk-plugin: Show git-modified files classified by ticket writes: scope
# tk-plugin-version: 1.0.0
#
# Usage:
#   tk scope <ticket-id>            Pretty-printed scope report
#   tk scope <ticket-id> --stage    Emit `cd <repo> && git add <paths>` ready to run
#   tk scope <ticket-id> --json     Machine-readable JSON output
#
# Reports four sets:
#   - In scope, modified         — files in writes: that are git-modified ("stage these")
#   - Out of scope, modified     — files modified but NOT in writes: ("scope drift — raise")
#   - Declared, not modified     — files in writes: that haven't been touched yet ("incomplete?")
#   - Declared, modified         — count for sanity
#
# Default mode exits non-zero if out-of-scope modifications are present.
# --stage refuses to emit a stage command if drift exists; pipe `| sh`
# only when the report is clean.
# --json always exits 0; the consumer decides what to do.
#
# Matches by exact path (git-repo-relative) OR by absolute path —
# writes: entries in tk tickets often use absolute paths; `git status
# --porcelain` emits repo-relative. The match handles both forms.
#
# Glob support (v1.2.0+): writes: entries may be bash glob patterns.
#   /abs/path/packages/frontend/**            — anything under that prefix
#   /abs/path/packages/frontend/**/*.ts       — only .ts files at any depth
#   packages/frontend/**                      — same, repo-relative form
# Globs are matched via bash [[ ]] pattern semantics: * (and ** equivalently)
# match any sequence including '/'; ? matches one char; [abc] matches a class.
# Literal paths still work as exact match — non-glob writes: entries behave
# unchanged. Prefer globs over enumerating every file when the intent is "all
# files under this prefix"; it's more compact and less brittle to scope drift
# under a directory boundary you've already declared.
#
# Agents: if "Out of scope" is non-empty during implementation, STOP
# and follow the scope-expansion protocol in the ticket-writer skill
# (tk add-note + wait for caller approval). Never silently expand.

set -euo pipefail

# ── Argument parsing ─────────────────────────────────────────
MODE="pretty"
TICKET_ID=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --stage) MODE="stage"; shift ;;
        --json)  MODE="json";  shift ;;
        -h|--help)
            cat <<'EOF'
tk scope — show git-modified files classified by ticket writes: scope.

Usage:
  tk scope <ticket-id>             Pretty-printed scope report
  tk scope <ticket-id> --stage     Emit `cd <repo> && git add <paths>`
                                   for the in-scope subset only;
                                   exits non-zero on drift.
  tk scope <ticket-id> --json      Machine-readable JSON output.

Exit codes (pretty mode):
  0   In scope only OR no modifications.
  1   Any out-of-scope modifications present (drift).

Exit codes (stage mode):
  0   Stage command emitted (clean scope, files to add).
  1   Drift present, no in-scope modifications, or other error.

Exit codes (json mode): always 0.
EOF
            exit 0
            ;;
        --*) echo "Unknown flag: $1" >&2; exit 1 ;;
        *)
            if [[ -n "$TICKET_ID" ]]; then
                echo "Error: too many arguments" >&2
                exit 1
            fi
            TICKET_ID="$1"; shift
            ;;
    esac
done

if [[ -z "$TICKET_ID" ]]; then
    cat >&2 <<'EOF'
Usage: tk scope <ticket-id> [--stage|--json]

Shows git-modified files classified by the ticket's writes: scope.
Run with -h for full help.
EOF
    exit 1
fi

TICKETS_DIR="${TICKETS_DIR:-.tickets}"
FILE="$TICKETS_DIR/${TICKET_ID}.md"
if [[ ! -f "$FILE" ]]; then
    echo "Error: ticket not found at $FILE" >&2
    exit 1
fi

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
    echo "Error: not in a git repository" >&2
    exit 1
}

# ── Extract writes: paths from ticket frontmatter ─────────────
declare -a writes=()
while IFS= read -r w; do
    [[ -n "$w" ]] && writes+=("$w")
done < <(awk '
    BEGIN { fm_state = "before"; in_writes = 0 }
    /^---$/ {
        if (fm_state == "before") { fm_state = "inside"; next }
        else if (fm_state == "inside") { exit }
    }
    fm_state == "inside" && /^writes:/ { in_writes = 1; next }
    fm_state == "inside" && in_writes && /^  - / {
        sub(/^  - /, "")
        print
        next
    }
    fm_state == "inside" && /^[a-z]/ { in_writes = 0 }
' "$FILE")

# ── Collect git status ───────────────────────────────────────
declare -a status_lines=()
while IFS= read -r line; do
    [[ -n "$line" ]] && status_lines+=("$line")
done < <(cd "$REPO_ROOT" && git status --porcelain)

# Helper: extract path from a porcelain line, handling rename arrows.
extract_path() {
    local line="$1" path
    path="${line:3}"
    [[ "$path" == *" -> "* ]] && path="${path##* -> }"
    printf '%s' "$path"
}

# Helper: does a git path (repo-relative) match a writes: entry?
# writes: entries may be:
#   - repo-relative literal:    plugins/ticket-scope
#   - absolute literal:         /Users/foo/repo/plugins/ticket-scope
#   - repo-relative glob:       plugins/**
#   - absolute glob:            /Users/foo/repo/packages/frontend/**/*.ts
# Unquoted RHS is intentional — bash [[ ]] treats unquoted patterns as
# globs. With a literal entry, this collapses to exact-string equality.
# shellcheck disable=SC2053  # intentional unquoted RHS for glob matching
path_matches_write() {
    local path="$1" w="$2"
    local abs="$REPO_ROOT/$path"
    [[ "$path" == $w || "$abs" == $w ]]
}

# ── Build the four sets ──────────────────────────────────────
declare -a in_scope_lines=()    # full porcelain lines, in scope
declare -a in_scope_paths=()    # repo-relative paths, in scope (for --stage)
declare -a out_scope_lines=()   # full porcelain lines, out of scope

for line in "${status_lines[@]}"; do
    path=$(extract_path "$line")
    matched=0
    for w in "${writes[@]+"${writes[@]}"}"; do
        if path_matches_write "$path" "$w"; then
            matched=1; break
        fi
    done
    if [[ $matched -eq 1 ]]; then
        in_scope_lines+=("$line")
        in_scope_paths+=("$path")
    else
        out_scope_lines+=("$line")
    fi
done

# Declared-but-not-modified: writes: entries with no matching modified file.
declare -a declared_not_modified=()
for w in "${writes[@]+"${writes[@]}"}"; do
    found=0
    for line in "${status_lines[@]+"${status_lines[@]}"}"; do
        path=$(extract_path "$line")
        if path_matches_write "$path" "$w"; then
            found=1; break
        fi
    done
    [[ $found -eq 0 ]] && declared_not_modified+=("$w")
done

# ── Output dispatch ──────────────────────────────────────────
case "$MODE" in

    pretty)
        echo "Ticket: $TICKET_ID"
        echo "writes: scope (${#writes[@]} paths declared)"
        echo ""

        if [[ ${#status_lines[@]} -eq 0 ]]; then
            echo "No modified files in working tree."
            if [[ ${#declared_not_modified[@]} -gt 0 ]]; then
                echo ""
                echo "Declared, not modified (${#declared_not_modified[@]}):"
                for w in "${declared_not_modified[@]}"; do
                    echo "  $w"
                done
            fi
            exit 0
        fi

        if [[ ${#writes[@]} -eq 0 ]]; then
            echo "Warning: no writes: paths declared — cannot classify scope."
            echo "Showing all git-modified files:"
            for l in "${status_lines[@]}"; do echo "  $l"; done
            exit 0
        fi

        if [[ ${#in_scope_lines[@]} -gt 0 ]]; then
            echo "In scope, modified (${#in_scope_lines[@]} files):"
            for l in "${in_scope_lines[@]}"; do echo "  $l"; done
        else
            echo "In scope, modified: none."
        fi
        echo ""

        if [[ ${#out_scope_lines[@]} -gt 0 ]]; then
            echo "Out of scope, modified (${#out_scope_lines[@]} files):"
            for l in "${out_scope_lines[@]}"; do echo "  $l"; done
        else
            echo "Out of scope, modified: none."
        fi
        echo ""

        if [[ ${#declared_not_modified[@]} -gt 0 ]]; then
            echo "Declared, not modified (${#declared_not_modified[@]}):"
            for w in "${declared_not_modified[@]}"; do echo "  $w"; done
        else
            echo "Declared, not modified: none."
        fi

        # Exit non-zero on drift (out-of-scope) per existing semantics.
        # Declared-but-not-modified is reported but doesn't fail —
        # could mean "not done yet," not necessarily an error.
        [[ ${#out_scope_lines[@]} -eq 0 ]]
        ;;

    stage)
        if [[ ${#out_scope_lines[@]} -gt 0 ]]; then
            echo "Error: ${#out_scope_lines[@]} out-of-scope modification(s) — refusing to emit stage command." >&2
            echo "Run \`tk scope $TICKET_ID\` to see drift, then resolve via the scope-expansion protocol." >&2
            exit 1
        fi
        if [[ ${#in_scope_paths[@]} -eq 0 ]]; then
            echo "Error: no in-scope modifications to stage." >&2
            exit 1
        fi
        # Emit a single command; quote paths with %q for safety against spaces.
        printf 'cd %q && git add' "$REPO_ROOT"
        for p in "${in_scope_paths[@]}"; do
            printf ' %q' "$p"
        done
        printf '\n'
        ;;

    json)
        # Build JSON arrays from the bash arrays. jq -n -R --slurp builds
        # a clean array from newline-separated input; safer than hand-
        # escaping shell strings.
        json_array() {
            if [[ $# -eq 0 ]]; then
                echo "[]"
                return
            fi
            printf '%s\n' "$@" | jq -R . | jq -s .
        }

        # Use jq to assemble the final object so escaping is correct.
        in_scope_json=$(json_array "${in_scope_paths[@]+"${in_scope_paths[@]}"}")
        out_scope_paths=()
        for line in "${out_scope_lines[@]+"${out_scope_lines[@]}"}"; do
            out_scope_paths+=("$(extract_path "$line")")
        done
        out_scope_json=$(json_array "${out_scope_paths[@]+"${out_scope_paths[@]}"}")
        declared_not_modified_json=$(json_array "${declared_not_modified[@]+"${declared_not_modified[@]}"}")

        jq -n \
            --arg ticket_id "$TICKET_ID" \
            --argjson writes_count "${#writes[@]}" \
            --argjson in_scope "$in_scope_json" \
            --argjson out_of_scope "$out_scope_json" \
            --argjson declared_not_modified "$declared_not_modified_json" \
            '{
                ticket_id: $ticket_id,
                writes_declared: $writes_count,
                in_scope_modified: $in_scope,
                out_of_scope_modified: $out_of_scope,
                declared_not_modified: $declared_not_modified,
                drift: (($out_of_scope | length) > 0)
             }'
        ;;
esac
