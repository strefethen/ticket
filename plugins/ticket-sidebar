#!/usr/bin/env bash
# tk-plugin: Generate _sidebar.json from .tickets/*.md for the fullstack-starter docs engine
# tk-plugin-version: 0.13.0
#
# Scans every .md ticket in TICKETS_DIR, groups by computed status
# (ready / in_progress / blocked — NOT closed), then sub-groups within each
# status by priority (P0, P1, P2...). Emits nested _sidebar.json that the
# fullstack-starter docs engine consumes.
#
# Closed tickets are NOT emitted in _sidebar.json (see ticket fs-va9q).
# Closed history lives in a sibling closed-tickets.md (fs-4jeu) that
# this plugin also generates on each run. Epic subsections exclude
# deferred and closed tickets so the tree view stays focused on active work.
#
# Outputs (all sentinel-guarded for non-destructive overwrite):
#   _sidebar.json       — the nav JSON
#   index.md            — tree view with a footer link to closed-tickets.md
#   closed-tickets.md   — historical archive of closed tickets
#
# For Blocked items, appends the first still-open blocker id inline in
# the item title: "fs-fg80 — Render deps nav (← fs-rote)".
#
# Invocation:
#   tk sidebar            # via tk dispatch; TICKETS_DIR is set for us
#   ticket-sidebar        # direct; falls back to ./.tickets
#
# Output: $TICKETS_DIR/_sidebar.json (overwritten atomically)

set -euo pipefail

TICKETS_DIR="${TICKETS_DIR:-.tickets}"

if [[ ! -d "$TICKETS_DIR" ]]; then
    echo "Error: $TICKETS_DIR does not exist" >&2
    exit 1
fi

# Detect repo name for H1 self-identification on the index page.
# Prefers git toplevel basename; falls back to the parent dir of
# TICKETS_DIR. Empty if neither resolves — H1 then renders bare.
if REPO_ROOT=$(cd "$TICKETS_DIR" && git rev-parse --show-toplevel 2>/dev/null); then
    REPO_NAME=$(basename "$REPO_ROOT")
elif TICKETS_PARENT=$(cd "$TICKETS_DIR/.." 2>/dev/null && pwd); then
    REPO_NAME=$(basename "$TICKETS_PARENT")
else
    REPO_NAME=""
fi

shopt -s nullglob
files=("$TICKETS_DIR"/*.md)
shopt -u nullglob

ticket_files=()
for f in "${files[@]}"; do
    case "$(basename "$f")" in
        _sidebar.json|_*|index.md|closed-tickets.md) continue ;;
        *) ticket_files+=("$f") ;;
    esac
done

TMP_OUT="$(mktemp "${TMPDIR:-/tmp}/ticket-sidebar.XXXXXX")"
trap 'rm -f "$TMP_OUT"' EXIT

if [[ ${#ticket_files[@]} -eq 0 ]]; then
    cat > "$TMP_OUT" <<'EOF'
{
  "sections": []
}
EOF
else
    awk '
    BEGIN { FS = ": "; in_front = 0 }

    FNR == 1 {
        if (prev_file) store()
        id = ""; status = ""; title = ""; deps = ""
        priority = ""; type = ""; parent = ""; epics = ""
        in_front = 0
        prev_file = FILENAME
    }

    /^---$/ { in_front = !in_front; next }
    in_front && /^id:/       { id = $2 }
    in_front && /^status:/   { status = $2 }
    in_front && /^priority:/ { priority = $2 }
    in_front && /^type:/     { type = $2 }
    in_front && /^parent:/   { parent = $2 }
    in_front && /^deps:/ {
        deps = $2
        gsub(/[\[\] ]/, "", deps)
    }
    in_front && /^tags:/ {
        # Extract epic:* tag values from inline array: tags: [a, epic:b, c]
        val = $0
        sub(/^tags:[ ]*/, "", val)
        gsub(/^\[|\]$/, "", val)
        n = split(val, tagitems, ", *")
        for (j = 1; j <= n; j++) {
            gsub(/^ +| +$/, "", tagitems[j])
            gsub(/^["\047]|["\047]$/, "", tagitems[j])
            if (tagitems[j] ~ /^epic:/) {
                epics = (epics == "") ? tagitems[j] : epics "," tagitems[j]
            }
        }
    }
    !in_front && /^# / && title == "" { title = substr($0, 3) }

    function store() {
        if (id == "") return
        statuses[id]   = status
        titles[id]     = title
        deps_map[id]   = deps
        priorities[id] = (priority != "") ? priority : "2"
        parents[id]    = parent
        epics_map[id]  = epics
        ids[++count]   = id
    }

    # Emit `"blocked_by": [{id,priority},...]` for a ticket. Filters
    # to active blockers only (closed deps are already resolved so
    # they no longer block). Stale references (deps pointing at
    # tickets outside the corpus) are skipped defensively.
    function emit_blocked_by(tid,    dlist, n, arr, k, d, first) {
        printf "\"blocked_by\": ["
        dlist = deps_map[tid]
        if (dlist == "") { printf "]"; return }
        n = split(dlist, arr, ",")
        first = 1
        for (k = 1; k <= n; k++) {
            d = arr[k]
            if (d == "") continue
            if (!(d in statuses)) continue
            if (statuses[d] == "closed") continue
            if (!first) printf ","
            printf "{\"id\":\"%s\",\"priority\":%d}", d, priorities[d] + 0
            first = 0
        }
        printf "]"
    }

    function json_escape(s,   r) {
        r = s
        gsub(/\\/, "\\\\", r)
        gsub(/"/,  "\\\"", r)
        gsub(/\t/, "\\t",  r)
        gsub(/\r/, "\\r",  r)
        gsub(/\n/, "\\n",  r)
        return r
    }

    # Classify into ready / in_progress / blocked / closed / deferred.
    # "deferred" is bucketed but never rendered (not in section_order),
    # mirroring the core tk cmd_ready behavior that excludes deferred
    # tickets from active queues.
    function group_for(tid,   s, deps_list, n, k, dep) {
        s = statuses[tid]
        if (s == "closed") return "closed"
        if (s == "deferred") return "deferred"
        if (s == "in_progress") return "in_progress"
        deps_list = deps_map[tid]
        if (deps_list == "") return "ready"
        n = split(deps_list, darr, ",")
        for (k = 1; k <= n; k++) {
            dep = darr[k]
            if (dep != "" && statuses[dep] != "closed") return "blocked"
        }
        return "ready"
    }

    # Return the first still-open dep id, or "".
    function first_blocker(tid,   deps_list, n, k, dep) {
        deps_list = deps_map[tid]
        if (deps_list == "") return ""
        n = split(deps_list, darr, ",")
        for (k = 1; k <= n; k++) {
            dep = darr[k]
            if (dep != "" && statuses[dep] != "closed") return dep
        }
        return ""
    }

    END {
        if (prev_file) store()

        # Bucket by (group, priority).
        for (i = 1; i <= count; i++) {
            tid = ids[i]
            g = group_for(tid)
            p = priorities[tid] + 0
            bucket[g, p, ++bcount[g, p]] = tid
            seen_priority[g, p] = 1
        }

        # Closed is intentionally excluded per fs-va9q: closed tickets
        # dominate screen real estate at real-world volume, drowning
        # active work in the primary views. History lives in a separate
        # closed-tickets.md (fs-4jeu).
        section_order[1] = "ready";       section_label["ready"]       = "Ready"
        section_order[2] = "in_progress"; section_label["in_progress"] = "In Progress"
        section_order[3] = "blocked";     section_label["blocked"]     = "Blocked"

        # Build epic → tickets map. An epic section appears for every
        # unique epic:* tag found across the corpus; a ticket is listed
        # under every epic it belongs to (multi-epic membership is
        # allowed). The Epics section is emitted FIRST so agents and
        # readers see the work-stream rollup before the status queues.
        # Deferred and closed tickets are excluded — they are explicitly
        # parked or archived and should not inflate the epic count or
        # appear under the epic name, mirroring the treatment in the
        # status queues.
        epic_n = 0
        for (i = 1; i <= count; i++) {
            tid = ids[i]
            if (statuses[tid] == "deferred" || statuses[tid] == "closed") continue
            el = epics_map[tid]
            if (el == "") continue
            ne = split(el, earr, ",")
            for (k = 1; k <= ne; k++) {
                e = earr[k]
                if (e == "") continue
                epic_tickets[e, ++epic_count[e]] = tid
                if (!(e in all_epics)) {
                    all_epics[e] = 1
                    epic_list[++epic_n] = e
                }
            }
        }

        # Sort epics alphabetically for stable output
        for (i = 1; i <= epic_n; i++) {
            for (j = i + 1; j <= epic_n; j++) {
                if (epic_list[i] > epic_list[j]) {
                    tmp = epic_list[i]; epic_list[i] = epic_list[j]; epic_list[j] = tmp
                }
            }
        }

        # Per-group totals for the summary block in index.md. Classifies
        # each ticket via group_for (same logic as section bucketing) so
        # the counts match what the nav surfaces.
        total_count = count
        for (i = 1; i <= count; i++) {
            g = group_for(ids[i])
            group_counts[g]++
        }

        print "{"
        print "  \"sections\": ["

        first_section = 1

        # ── Epics section ─────────────────────────────────────────
        if (epic_n > 0) {
            printf "    {\n"
            printf "      \"title\": \"Epics\",\n"
            printf "      \"slug\":  \"epics\",\n"
            printf "      \"subsections\": [\n"

            first_sub = 1
            for (ei = 1; ei <= epic_n; ei++) {
                e = epic_list[ei]

                if (!first_sub) print ","
                first_sub = 0

                en = epic_count[e]
                for (i = 1; i <= en; i++) items[i] = epic_tickets[e, i]
                # Sort by (priority asc, id asc) — high-urgency tickets
                # surface first; ties resolved alphabetically by id.
                for (i = 1; i <= en; i++) {
                    for (j = i + 1; j <= en; j++) {
                        pi = priorities[items[i]] + 0
                        pj = priorities[items[j]] + 0
                        if (pj < pi || (pj == pi && items[j] < items[i])) {
                            tmp = items[i]; items[i] = items[j]; items[j] = tmp
                        }
                    }
                }

                display_name = e
                sub(/^epic:/, "", display_name)

                printf "        {\n"
                printf "          \"title\": \"%s (%d)\",\n", display_name, en
                printf "          \"slug\":  \"epics/%s\",\n", display_name
                printf "          \"items\": [\n"

                first_item = 1
                for (i = 1; i <= en; i++) {
                    iid = items[i]
                    t = titles[iid]
                    if (t == "") t = iid
                    if (!first_item) print ","
                    first_item = 0
                    et = json_escape(t)
                    printf "            { \"title\": \"%s — %s\", \"slug\": \"%s\", \"priority\": %d, ", iid, et, iid, priorities[iid] + 0
                    emit_blocked_by(iid)
                    printf " }"
                }

                printf "\n          ]\n"
                printf "        }"
            }

            printf "\n      ]\n"
            printf "    }"
            first_section = 0
        }

        for (si = 1; si <= 3; si++) {
            g = section_order[si]
            has_content = 0
            for (p = 0; p <= 4; p++) if (seen_priority[g, p]) { has_content = 1; break }
            if (!has_content) continue

            if (!first_section) print ","
            first_section = 0

            printf "    {\n"
            printf "      \"title\": \"%s\",\n", section_label[g]
            printf "      \"slug\":  \"%s\",\n", g
            printf "      \"subsections\": [\n"

            first_sub = 1
            for (p = 0; p <= 4; p++) {
                if (!seen_priority[g, p]) continue

                if (!first_sub) print ","
                first_sub = 0

                # Sort items within bucket by id
                n = bcount[g, p]
                for (i = 1; i <= n; i++) items[i] = bucket[g, p, i]
                for (i = 1; i <= n; i++) {
                    for (j = i + 1; j <= n; j++) {
                        if (items[i] > items[j]) {
                            tmp = items[i]; items[i] = items[j]; items[j] = tmp
                        }
                    }
                }

                printf "        {\n"
                printf "          \"title\": \"P%d (%d)\",\n", p, n
                printf "          \"slug\":  \"%s/P%d\",\n", g, p
                printf "          \"items\": [\n"

                first_item = 1
                for (i = 1; i <= n; i++) {
                    iid = items[i]
                    t = titles[iid]
                    if (t == "") t = iid

                    # Inline "(← blocker)" suffix was previously used on
                    # Blocked-section items. The Blocked-by sub-bullet
                    # rendered from the blocked_by array now carries
                    # richer info (all blockers + their priorities), so
                    # the suffix is no longer appended.

                    if (!first_item) print ","
                    first_item = 0
                    et = json_escape(t)
                    printf "            { \"title\": \"%s — %s\", \"slug\": \"%s\", \"priority\": %d, ", iid, et, iid, priorities[iid] + 0
                    emit_blocked_by(iid)
                    printf " }"
                }

                printf "\n          ]\n"
                printf "        }"
            }

            printf "\n      ]\n"
            printf "    }"
        }
        printf "\n  ],\n"
        printf "  \"summary\": {\n"
        printf "    \"total\": %d,\n",        total_count
        printf "    \"ready\": %d,\n",        (group_counts["ready"]       + 0)
        printf "    \"in_progress\": %d,\n",  (group_counts["in_progress"] + 0)
        printf "    \"blocked\": %d,\n",      (group_counts["blocked"]     + 0)
        printf "    \"deferred\": %d,\n",     (group_counts["deferred"]    + 0)
        printf "    \"closed\": %d\n",        (group_counts["closed"]      + 0)
        printf "  }\n}\n"
    }
    ' "${ticket_files[@]}" > "$TMP_OUT"
fi

if ! python3 -c 'import json, sys; json.load(open(sys.argv[1]))' "$TMP_OUT" 2>/dev/null; then
    echo "Error: generated _sidebar.json failed JSON validation. Not writing." >&2
    echo "Offending output saved to: $TMP_OUT" >&2
    trap - EXIT
    exit 1
fi

mv "$TMP_OUT" "$TICKETS_DIR/_sidebar.json"
trap - EXIT

# ── index.md generation ─────────────────────────────────────────
# The generated index.md is idempotent and non-destructive: we only
# overwrite a file that carries our sentinel comment on line 1, so a
# hand-authored index.md is never clobbered.

SENTINEL="<!-- generated by ticket-sidebar"

should_write_index=true
if [[ -f "$TICKETS_DIR/index.md" ]]; then
    if ! head -n 1 "$TICKETS_DIR/index.md" 2>/dev/null | grep -qF "$SENTINEL"; then
        should_write_index=false
    fi
fi

if $should_write_index; then
    if command -v jq >/dev/null 2>&1; then
        INDEX_TMP="$(mktemp "${TMPDIR:-/tmp}/ticket-index.XXXXXX")"
        jq -r --arg repo "$REPO_NAME" '
            def emoji(p): if p == 1 then "🔴" elif p == 2 then "🟡" elif p == 3 then "🟢" else "⚪" end;
            def blocker_md: emoji(.priority) + " [" + .id + "](./" + .id + ".md)";
            def item_line:
                "- " + emoji(.priority) + " [" + .title + "](./" + .slug + ".md)" +
                (if ((.blocked_by // []) | length) > 0
                 then "\n  - Blocked by: " + ((.blocked_by | map(blocker_md)) | join(", "))
                 else "" end);
            (.summary // {}) as $s |
            "<!-- generated by ticket-sidebar — do not hand-edit, rerun tk sidebar -->\n\n" +
            "# Tickets" + (if $repo != "" then " — " + $repo else "" end) + "\n" +
            ((.sections // []) | map(
                "\n## " + .title + "\n" +
                (
                    ((.subsections // []) | map(
                        "\n### " + .title + "\n\n" +
                        (((.items // []) | map(item_line)) | join("\n"))
                    ) | join("\n"))
                    +
                    (if (.items // []) | length > 0
                        then "\n" + (((.items // []) | map(item_line)) | join("\n"))
                        else ""
                    end)
                )
            ) | join("\n")) + "\n\n---\n\n**[" + ($s.closed // 0 | tostring) + " closed tickets →](./closed-tickets.md)**\n"
        ' "$TICKETS_DIR/_sidebar.json" > "$INDEX_TMP"
        mv "$INDEX_TMP" "$TICKETS_DIR/index.md"
        index_note=" + index.md"
    else
        # jq not available — fall back to a minimal scaffold once, same as before.
        if [[ ! -f "$TICKETS_DIR/index.md" ]]; then
            cat > "$TICKETS_DIR/index.md" <<'EOF'
<!-- generated by ticket-sidebar — do not hand-edit, rerun tk sidebar -->

# Tickets

jq is not installed, so the tree view could not be generated. Install jq to enable
the full tree rendering (`brew install jq`). Until then, browse via the sidebar.
EOF
            index_note=" + index.md (fallback)"
        else
            index_note=""
        fi
    fi
else
    index_note=""
fi

# ── closed-tickets.md generation (fs-4jeu) ──────────────────────
# Historical archive of closed tickets, one page per doc set.
# Sentinel-guarded like index.md, so a hand-authored version is
# never clobbered. Sort order: lexicographic id descending as a
# proxy for created-date (tk doesn't record closed_at today).

closed_note=""
should_write_closed=true
if [[ -f "$TICKETS_DIR/closed-tickets.md" ]]; then
    if ! head -n 1 "$TICKETS_DIR/closed-tickets.md" 2>/dev/null | grep -qF "$SENTINEL"; then
        should_write_closed=false
    fi
fi

if $should_write_closed; then
    CLOSED_TMP="$(mktemp "${TMPDIR:-/tmp}/ticket-closed.XXXXXX")"
    if [[ ${#ticket_files[@]} -gt 0 ]]; then
        awk -v repo="$REPO_NAME" '
        BEGIN { FS = ": "; fm_state = "before" }
        FNR == 1 {
            if (prev) emit()
            id = ""; status = ""; title = ""; type_ = ""; priority = ""
            last_close = ""
            fm_state = "before"
            prev = FILENAME
        }
        /^---$/ {
            if (fm_state == "before") { fm_state = "inside" }
            else if (fm_state == "inside") { fm_state = "after" }
            next
        }
        fm_state == "inside" {
            # FS=": " so $1 is the key WITHOUT the trailing colon.
            if ($1 == "id") id = $2
            else if ($1 == "status") status = $2
            else if ($1 == "type") type_ = $2
            else if ($1 == "priority") priority = $2
        }
        fm_state == "after" && /^# / && title == "" { title = substr($0, 3) }
        # Last body line starting with "Closed: " wins — captures the
        # reason from the most recent close (after any reopen+reclose).
        fm_state == "after" && /^Closed: / { last_close = substr($0, 9) }

        function emit() {
            if (status != "closed" || id == "") return
            ids[++n] = id
            titles[id] = title
            types[id] = type_
            priorities[id] = priority
            reasons[id] = last_close
        }

        END {
            if (prev) emit()

            # Sort ids descending (lexicographic ~ created-date proxy)
            for (i = 1; i <= n; i++) {
                for (j = i + 1; j <= n; j++) {
                    if (ids[i] < ids[j]) {
                        tmp = ids[i]; ids[i] = ids[j]; ids[j] = tmp
                    }
                }
            }

            print "<!-- generated by ticket-sidebar — do not hand-edit, rerun tk sidebar -->"
            print ""
            if (repo != "") {
                printf "# Closed tickets — %s\n\n", repo
            } else {
                print "# Closed tickets"
                print ""
            }
            print "Historical archive of closed tickets for this doc set. Regenerated on each `tk sidebar` run. Active work lives in the sidebar and [tree index](./index.md)."
            print ""
            if (n == 0) {
                print "_No closed tickets yet._"
            } else {
                printf "Total: **%d**\n\n", n
                for (i = 1; i <= n; i++) {
                    tid = ids[i]
                    printf "## [%s](./%s.md) — %s\n\n", tid, tid, titles[tid]
                    if (types[tid]      != "") printf "- **Type**: %s\n",     types[tid]
                    if (priorities[tid] != "") printf "- **Priority**: P%s\n", priorities[tid]
                    if (reasons[tid]    != "") printf "- **Close reason**: %s\n", reasons[tid]
                    print ""
                }
            }
            print "---"
            print ""
            print "[Back to tickets](./index.md)"
        }
        ' "${ticket_files[@]}" > "$CLOSED_TMP"
    else
        if [[ -n "$REPO_NAME" ]]; then
            cat > "$CLOSED_TMP" <<EOF
<!-- generated by ticket-sidebar — do not hand-edit, rerun tk sidebar -->

# Closed tickets — $REPO_NAME

_No tickets in this set yet._
EOF
        else
            cat > "$CLOSED_TMP" <<'EOF'
<!-- generated by ticket-sidebar — do not hand-edit, rerun tk sidebar -->

# Closed tickets

_No tickets in this set yet._
EOF
        fi
    fi
    mv "$CLOSED_TMP" "$TICKETS_DIR/closed-tickets.md"
    closed_note=" + closed-tickets.md"
fi

count=${#ticket_files[@]}
echo "ticket-sidebar: wrote $TICKETS_DIR/_sidebar.json ($count tickets)${index_note}${closed_note}"
