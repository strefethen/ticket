#!/usr/bin/env bash
# tk-plugin: Open or update ticket sections
# tk-plugin-version: 1.5.0
set -euo pipefail

usage() {
    echo "Usage: tk edit <id> [--goal TEXT] [--design TEXT] [--acceptance TEXT] [--testing TEXT]" >&2
}

if [[ $# -lt 1 ]]; then
    usage
    exit 1
fi

id=""
goal_file=""
design_file=""
acceptance_file=""
testing_file=""
tmp_dir=""
stdin_source_flag=""

cleanup() {
    if [[ -n "$tmp_dir" ]]; then
        rm -rf "$tmp_dir"
    fi
    return 0
}
trap cleanup EXIT

ensure_tmp_dir() {
    if [[ -z "$tmp_dir" ]]; then
        tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/ticket-edit.XXXXXX")
    fi
}

section_source_file() {
    local flag="$1"
    local value="$2"
    local target_var="$3"
    local out_file

    ensure_tmp_dir
    out_file="$tmp_dir/section.$(printf '%s' "$flag" | tr -c 'A-Za-z0-9' '_').$$"

    if [[ "$value" == "@-" ]]; then
        if [[ -n "$stdin_source_flag" ]]; then
            echo "Error: @- can only be used by one body section flag" >&2
            exit 1
        fi
        stdin_source_flag="$flag"
        cat > "$out_file"
    elif [[ "$value" == @* ]]; then
        echo "Error: $flag only supports inline text or @- stdin; @file inputs are not supported" >&2
        exit 1
    else
        printf '%s\n' "$value" > "$out_file"
    fi

    printf -v "$target_var" '%s' "$out_file"
}

replace_existing_section() {
    local file="$1"
    local heading="$2"
    local content_file="$3"
    local tmp="${file}.tmp.$$"

    awk -v heading="$heading" -v content_file="$content_file" '
        BEGIN {
            content_count = 0
            while ((getline line < content_file) > 0) {
                content[++content_count] = line
            }
            close(content_file)
            replacing = 0
        }

        function emit_section() {
            print heading
            print ""
            for (i = 1; i <= content_count; i++) {
                print content[i]
            }
            print ""
        }

        $0 == heading {
            emit_section()
            replacing = 1
            next
        }

        replacing && /^##[[:space:]]+/ {
            replacing = 0
        }

        replacing {
            next
        }

        {
            print
        }
    ' "$file" > "$tmp" && mv "$tmp" "$file"
}

append_section() {
    local file="$1"
    local heading="$2"
    local content_file="$3"

    {
        printf '\n%s\n\n' "$heading"
        cat "$content_file"
        printf '\n'
    } >> "$file"
}

update_section() {
    local file="$1"
    local heading="$2"
    local content_file="$3"

    if grep -Fxq "$heading" "$file"; then
        replace_existing_section "$file" "$heading" "$content_file"
    else
        append_section "$file" "$heading" "$content_file"
    fi
}

require_value() {
    local flag="$1"
    local count="$2"
    if [[ "$count" -lt 2 ]]; then
        echo "Error: $flag requires a value" >&2
        exit 1
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --from-file)
            echo "Error: --from-file has been removed; use body section flags such as --design @- or --acceptance @-" >&2
            exit 1
            ;;
        -d|--description|--goal)
            require_value "$1" "$#"
            section_source_file "$1" "$2" goal_file
            shift 2
            ;;
        --design)
            require_value "$1" "$#"
            section_source_file "$1" "$2" design_file
            shift 2
            ;;
        --acceptance)
            require_value "$1" "$#"
            section_source_file "$1" "$2" acceptance_file
            shift 2
            ;;
        --testing|--testing-obligations)
            require_value "$1" "$#"
            section_source_file "$1" "$2" testing_file
            shift 2
            ;;
        -h|--help)
            cat <<'EOF'
tk edit — open or update ticket sections.

Usage:
  tk edit <id>                                  Open ticket in $EDITOR (TTY only)
  tk edit <id> --design TEXT --acceptance TEXT  Update body sections

Ticket storage is intentionally opaque to automation. Use structured commands
and body-section flags instead of assembling complete ticket files.
Non-interactive automation must pass body-section flags.

Body section flags mirror `tk create`:
  -d, --description, --goal      Update ## Goal
  --design                       Update ## Design
  --acceptance                   Update ## Acceptance Criteria
  --testing, --testing-obligations
                                 Update ## Testing Obligations

Section values may be inline text or @- to read from stdin. Only one body
section flag may use @- in a single command.
EOF
            exit 0
            ;;
        --*)
            echo "Unknown flag: $1" >&2
            exit 1
            ;;
        *)
            if [[ -n "$id" ]]; then
                echo "Error: too many arguments" >&2
                exit 1
            fi
            id="$1"
            shift
            ;;
    esac
done

if [[ -z "$id" ]]; then
    usage
    exit 1
fi

has_section_edits=0
if [[ -n "$goal_file" || -n "$design_file" || -n "$acceptance_file" || -n "$testing_file" ]]; then
    has_section_edits=1
fi

read -r id <<< "$id"

# Resolve ticket file (exact or partial match)
file="$TICKETS_DIR/${id}.md"
if [[ ! -f "$file" ]]; then
    matches=$(find "$TICKETS_DIR" -maxdepth 1 -name "*${id}*.md" 2>/dev/null)
    count=$(printf '%s\n' "$matches" | grep -c . 2>/dev/null || echo 0)
    if [[ "$count" -eq 1 ]]; then
        file="$matches"
    elif [[ "$count" -gt 1 ]]; then
        echo "Error: ambiguous ID '$id' matches multiple tickets" >&2
        exit 1
    else
        echo "Error: ticket '$id' not found" >&2
        exit 1
    fi
fi
resolved_id="${file##*/}"
resolved_id="${resolved_id%.md}"

if [[ "$has_section_edits" -eq 1 ]]; then
    [[ -n "$goal_file" ]] && update_section "$file" "## Goal" "$goal_file"
    [[ -n "$design_file" ]] && update_section "$file" "## Design" "$design_file"
    [[ -n "$acceptance_file" ]] && update_section "$file" "## Acceptance Criteria" "$acceptance_file"
    [[ -n "$testing_file" ]] && update_section "$file" "## Testing Obligations" "$testing_file"
    echo "Updated $resolved_id"
    exit 0
fi

if [ -t 0 ] && [ -t 1 ]; then
    "${EDITOR:-vi}" "$file"
else
    echo "Error: non-interactive edit requires body section flags" >&2
    exit 1
fi
